<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
          "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
          "https://checkstyle.org/dtds/configuration_1_3.dtd">

<module name="Checker">
    <property name="charset" value="UTF-8"/>
    <!--
         [Severity]
         Any naming violation fails the build (not a warning).
    -->
    <property name="severity" value="error"/>

    <module name="TreeWalker">
        <!--
             [Package naming]
             Every package segment must be lowercase.
             Valid: sns.blog.javalin.controller. Invalid: sns.blog.javalin.Controller.
        -->
        <module name="PackageName">
            <property name="format" value="^[a-z]+(\.[a-z][a-z0-9]*)*$"/>
            <message key="name.invalidPattern"
                     value="Package name ''{0}'' must be all lowercase to follow JDK conventions."/>
        </module>

        <!--
             [Type naming]
             Class and interface names start with a capital letter (PascalCase).
             Example: SocialMediaController, AccountService.
        -->
        <module name="TypeName">
            <property name="format" value="^[A-Z][a-zA-Z0-9]*$"/>
            <message key="name.invalidPattern"
                     value="Type name ''{0}'' must be PascalCase (e.g. MyClass)."/>
        </module>

        <!--
             [Method naming]
             Method names start with a lowercase letter (camelCase).
             Example: registerAccount, getMessageById.
        -->
        <module name="MethodName">
            <property name="format" value="^[a-z][a-zA-Z0-9]*$"/>
            <message key="name.invalidPattern"
                     value="Method name ''{0}'' must be camelCase (no underscores)."/>
        </module>

        <!--
             [Member naming]
             Field names are camelCase in Java (accountId).
             For snake_case JSON keys, use @JsonProperty("account_id") on the field.
        -->
        <module name="MemberName">
            <property name="format" value="^[a-z][a-zA-Z0-9]*$"/>
            <message key="name.invalidPattern"
                     value="Variable name ''{0}'' must be camelCase (no underscores)."/>
        </module>

        <!--
             [Parameter naming]
             Method parameters are camelCase. Example: messageId, accountId.
        -->
        <module name="ParameterName">
            <property name="format" value="^[a-z][a-zA-Z0-9]*$"/>
            <message key="name.invalidPattern"
                     value="Parameter name ''{0}'' must be camelCase."/>
        </module>

        <!--
             [Local naming]
             Variables inside methods are camelCase. Example: resultSet, rowCount.
        -->
        <module name="LocalVariableName">
            <property name="format" value="^[a-z][a-zA-Z0-9]*$"/>
            <message key="name.invalidPattern"
                     value="Local variable name ''{0}'' must be camelCase."/>
        </module>

        <!--
             [Constant naming]
             static final constants are ALL_CAPS with underscores.
             Example: MAX_RETRIES, DEFAULT_PORT.
        -->
        <module name="ConstantName">
            <property name="format" value="^[A-Z][A-Z0-9]*(_[A-Z0-9]+)*$"/>
        </module>
    </module>
</module>
